NODE_ENV=development
APP_ENV=local
PORT=3001
LOG_LEVEL=info

# Optional write protection for manual ingest/review endpoints.
# Do not paste OpenAI or other vendor API keys here.
AGENT_API_TOKEN=


# Shared data plane with the main platform.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
SUPABASE_RAW_INGEST_TABLE=raw_content_ingest
SUPABASE_PARSE_RESULTS_TABLE=content_parse_results
SUPABASE_REVIEW_QUEUE_TABLE=content_review_queue
SUPABASE_PUBLISHED_NEWS_TABLE=published_sector_news
SUPABASE_PUBLISHED_SIGNALS_TABLE=published_market_signals

# Model routing. Recommended default for this review workload: OpenAI + gpt-4.1-mini.
DEFAULT_MODEL_PROVIDER=openai
MODEL_TIMEOUT_MS=20000

# OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Perplexity can be used for corroboration / summarization, not as sole truth source.
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
ENABLE_PERPLEXITY_CORROBORATION=false

# Source adapters.
ENABLE_RSS_SOURCES=true
ENABLE_OFFICIAL_HTTP_SOURCES=true
ENABLE_TELEGRAM_USER_SOURCE=true
ENABLE_YOUTUBE_METADATA=false
YOUTUBE_API_KEY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=
TELEGRAM_SESSION_STRING=
ALLOWED_SOURCE_HOSTS=epdk.gov.tr,resmigazete.gov.tr,meteoroloji.gov.tr,afad.gov.tr,uab.gov.tr,ticaret.gov.tr
MAX_SOURCE_ITEMS_PER_RUN=20

# Queue / retry layer. Optional in phase 1.
ENABLE_REDIS=false
REDIS_URL=

# Optional scheduler knobs for `npm run ingest:once`.
INGESTION_CHANNEL_REFS=
INGESTION_LIMIT_PER_CHANNEL=20
INGESTION_TRIGGER_SOURCE=railway-scheduler

# Guardrails.
REVIEW_AUTOPUBLISH_ENABLED=false
REVIEW_AUTOPUBLISH_MIN_CONFIDENCE=0.9