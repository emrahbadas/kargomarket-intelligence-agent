{
  "name": "kargomarket-intelligence-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "ingest:once": "node dist/scripts/runTelegramIngestionCycle.js",
    "ingest:once:dev": "tsx src/scripts/runTelegramIngestionCycle.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^17.2.0",
    "fastify": "^5.6.1",
    "telegram": "^2.26.22",
    "youtube-transcript": "^1.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
